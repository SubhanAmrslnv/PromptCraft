{
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout -- *)",
      "Bash(git restore .)",
      "Bash(git branch -D*)",
      "Bash(git rebase -i*)",
      "Bash(git commit --amend*)",
      "Bash(git reflog delete*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-git-hooks.sh"
          }
        ]
      }
    ]
  }
}
